rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Members: public read, admin write
    match /members/{memberId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Notices: public read, admin write
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Content (about, history, committee): public read, admin write
    match /content/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Device tokens: any device can register/remove its own token
    match /device_tokens/{tokenId} {
      allow read, write: if true;
    }

    // App config: public read, admin write
    match /app_config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
