rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdminEmail() {
      return isSignedIn() && (
        request.auth.token.email == 'admin1@bhandaripariwar.app' ||
        request.auth.token.email == 'admin2@bhandaripariwar.app' ||
        request.auth.token.email == 'admin3@bhandaripariwar.app' ||
        request.auth.token.email == 'admin4@bhandaripariwar.app'
      );
    }

    function hasCurrentUserDoc() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/app_users/$(request.auth.uid));
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/app_users/$(request.auth.uid));
    }

    function isApprovedUser() {
      return isSignedIn() && (
        isAdminEmail() ||
        (
          hasCurrentUserDoc() &&
          currentUserDoc().data.status == 'approved'
        )
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isAdminEmail() ||
        (
          hasCurrentUserDoc() &&
          currentUserDoc().data.status == 'approved' &&
          currentUserDoc().data.role == 'admin'
        )
      );
    }

    function allowedProfileKeys() {
      return [
        'uid',
        'fullName',
        'contact',
        'email',
        'address',
        'languageCode',
        'status',
        'role',
        'notificationsEnabled',
        'createdAt',
        'updatedAt',
        'approvedAt',
        'approvedBy',
        'approvedByEmail',
        'lastLoginAt'
      ];
    }

    function canCreatePendingProfile(userId) {
      return isSelf(userId) &&
        request.resource.data.keys().hasOnly(allowedProfileKeys()) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.status == 'pending' &&
        request.resource.data.role == 'user';
    }

    function canCreateAdminProfile(userId) {
      return isSelf(userId) &&
        isAdminEmail() &&
        request.resource.data.keys().hasOnly(allowedProfileKeys()) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.status == 'approved' &&
        request.resource.data.role == 'admin';
    }

    function canUpdateOwnProfile(userId) {
      return isSelf(userId) &&
        request.resource.data.keys().hasOnly(allowedProfileKeys()) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.approvedAt == resource.data.approvedAt &&
        request.resource.data.approvedBy == resource.data.approvedBy &&
        request.resource.data.approvedByEmail == resource.data.approvedByEmail;
    }

    // Members: approved users can read, admins can write
    match /members/{memberId} {
      allow read: if isApprovedUser();
      allow write: if isAdmin();
    }

    // Notices: approved users can read, admins can write
    match /notices/{noticeId} {
      allow read: if isApprovedUser();
      allow write: if isAdmin();
    }

    // Content (about, history, committee): approved users can read, admins can write
    match /content/{docId} {
      allow read: if isApprovedUser();
      allow write: if isAdmin();
    }

    match /app_users/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create: if canCreatePendingProfile(userId) || canCreateAdminProfile(userId) || isAdmin();
      allow update: if canUpdateOwnProfile(userId) || isAdmin();
      allow delete: if (isSelf(userId) && resource.data.status == 'pending' && resource.data.role == 'user') || isAdmin();
    }

    match /device_tokens/{tokenId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'token',
          'uid',
          'email',
          'platform',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    // App config: approved users can read, admins can write
    match /app_config/{docId} {
      allow read: if isApprovedUser();
      allow write: if isAdmin();
    }
  }
}
